+// Libravatar/Gravatar spec requires normalising the email (trim + lowercase) before hashing
+const normalize = (str) => String(str).trim().toLowerCase();
+
+env.addFilter('md5', (str) => helper.md5(normalize(str)));
+env.addFilter('sha256', (str) => crypto.createHash('sha256').update(normalize(str)).digest('hex'));
 
